# ============================================================
# 妙境 Docker / NAS 部署环境变量模板
# 复制为 .env.docker 后修改：
# cp .env.docker.example .env.docker
# ============================================================

# ----- 对外访问 -----
MIAOJING_HTTP_PORT=5000
NEXT_PUBLIC_APP_URL=http://你的NAS地址:5000
APP_BASE_URL=http://你的NAS地址:5000

# ----- Compose 内置 PostgreSQL -----
POSTGRES_DB=miaojing
POSTGRES_USER=miaojing
POSTGRES_PASSWORD=change-this-postgres-password
LOCAL_DB_URL=postgresql://miaojing:change-this-postgres-password@postgres:5432/miaojing
LOCAL_DB_ANON_KEY=local-anon-key
LOCAL_DB_SERVICE_ROLE_KEY=local-service-role-key

# ----- 生产安全密钥，必须替换 -----
# 生成方式：openssl rand -hex 32
DATA_ENCRYPTION_KEY=change-this-data-encryption-key
JWT_SECRET=change-this-jwt-secret
GENERATION_INTERNAL_SECRET=change-this-generation-internal-secret

# ----- 管理员初始化/邀请 -----
ADMIN_INVITE_CODE=miaojing-admin-2024
ADMIN_DEFAULT_PASSWORD=change-this-admin-password
ENABLE_DANGER_ADMIN_CLEAR_USERS=false

# ----- 容器运行路径 -----
LOCAL_STORAGE_DIR=/data/storage
BACKUP_DIR=/data/backups
UPGRADE_STATE_DIR=/data/upgrade
MIAOJING_LOAD_ENV_FILE=0

# ----- 对象存储，可选 -----
# STORAGE_MODE=local
# OBJECT_STORAGE_BUCKET=
# OBJECT_STORAGE_REGION=auto
# OBJECT_STORAGE_ENDPOINT=
# OBJECT_STORAGE_ACCESS_KEY_ID=
# OBJECT_STORAGE_SECRET_ACCESS_KEY=
# OBJECT_STORAGE_FORCE_PATH_STYLE=true
# OBJECT_STORAGE_PREFIX=miaojing

# ----- 邮件，可选 -----
# EMAIL_ENABLED=false
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=465
# EMAIL_SMTP_SECURE=true
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASSWORD=
# EMAIL_FROM=
# EMAIL_FROM_NAME=妙境官方通知
